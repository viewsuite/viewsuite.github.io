---
// src/components/Footer.astro
// You can make the year dynamic if you want
// const currentYear = new Date().getFullYear();
---
<footer class="simple-footer">
    <p>ViewSuite · <a href="https://github.com/viewsuite/ViewSuite" target="_blank" rel="noopener">GitHub</a> · <a href="https://huggingface.co/ViewSuite" target="_blank" rel="noopener">Models &amp; Data</a> · <a href="https://github.com/viewsuite/ViewSuite/raw/main/viewsuite_paper.pdf" target="_blank" rel="noopener">Paper</a></p>
    <p>Template adapted from <a href="https://vagen-ai.github.io/" target="_blank" rel="noopener">VAGEN</a>.</p>
    </footer>
  
  <style>
    .simple-footer {
      background: linear-gradient(135deg, #eef2ff 0%, #e0e7ff 50%, #c7d2fe 100%);
      backdrop-filter: blur(10px);
      padding: 1.5rem 1rem;
      margin-top: 3rem;
      text-align: center;
      color: var(--text-secondary);
      font-size: 0.875rem;
      border-top: 1px solid rgba(99, 102, 241, 0.2);
      box-shadow: 0 -2px 10px rgba(99, 102, 241, 0.1);
    }
  
    .simple-footer p {
      margin: 0.25rem 0;
    }

    .simple-footer a {
      color: var(--accent-color);
      text-decoration: none;
      transition: color 0.2s ease;
      font-weight: 500;
    }

    .simple-footer a:hover {
      color: var(--accent-hover);
      text-decoration: underline;
    }
  </style>