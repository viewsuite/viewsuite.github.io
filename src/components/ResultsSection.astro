      <table class="results-table">
        <thead>
          <tr>
            <th rowspan="2" class="model-col">Model</th>
            <th colspan="3" class="grp grp-p2v">Path-to-View</th>
            <th colspan="3" class="grp grp-v2p">View-to-Path</th>
            <th colspan="3" class="grp grp-ivp">Interactive View Planning</th>
            <th rowspan="2">Overall</th>
          </tr>
          <tr>
            <th>Short</th><th>Long</th><th>All</th>
            <th>Short</th><th>Long</th><th>All</th>
            <th>Short</th><th>Long</th><th>All</th>
          </tr>
        </thead>
