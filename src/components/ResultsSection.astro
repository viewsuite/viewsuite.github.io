            <td>28.8</td><td><b>17.4</b></td><td><b>21.4</b></td>
            <td>39.9</td>
          </tr>
          <tr>
            <td>GPT-5.4</td>
            <td>57.1</td><td>42.9</td><td>47.8</td>
            <td>60.5</td><td>37.5</td><td>45.6</td>
            <td><b>33.7</b></td><td>7.5</td><td>16.6</td>
            <td>36.7</td>
          </tr>
          <tr>
