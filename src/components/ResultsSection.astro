          <tr>
            <td>GPT-5.1</td>
            <td>60.3</td><td>35.1</td><td>43.9</td>
            <td>52.4</td><td>33.4</td><td>40.1</td>
            <td>12.0</td><td>3.2</td><td>6.2</td>
